NEXT_PUBLIC_APP_URL=
ANTHROPIC_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
TAVILY_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Per-user OAuth callback. Must match an Authorized redirect URI in Google Cloud
# Console: https://knetc.team/api/oauth/google/callback (prod),
# http://localhost:3000/api/oauth/google/callback (dev). If unset, the route
# falls back to the request origin + /api/oauth/google/callback.
GOOGLE_REDIRECT_URI=
# DEPRECATED — global service refresh token. No longer read after the per-user
# OAuth migration. Safe to remove once verified in production.
GOOGLE_REFRESH_TOKEN=
# 32-byte base64 key for AES-256-GCM encryption of stored OAuth refresh/access
# tokens. Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
KNOWLEDGE_BASE_DOC_ID=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
RESEND_API_KEY=
FEEDBACK_EMAIL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# E2B Desktop (computer use)
E2B_API_KEY=

# Proxycurl — LinkedIn public profile lookups for Dana. Optional.
# Without this, Dana falls back to Tavily search snippets (lower fidelity).
# Get a key at https://nubela.co/proxycurl/
PROXYCURL_API_KEY=

# Random hex (e.g. `openssl rand -hex 32`). Required by /api/cron/desktop-cleanup;
# Vercel Cron passes it via the Authorization: Bearer <secret> header.
CRON_SECRET=
